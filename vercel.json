{
  "buildCommand": "cd frontend && npm install && npm run build",
  "functions": {
    "api/index.py": {
      "includeFiles": "backend/**",
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/health", "destination": "/api" },
    { "source": "/assets/(.*)", "destination": "/frontend/dist/assets/$1" },
    { "source": "/icons/(.*)", "destination": "/frontend/dist/icons/$1" },
    { "source": "/sw.js", "destination": "/frontend/dist/sw.js" },
    { "source": "/workbox-(.*).js", "destination": "/frontend/dist/workbox-$1.js" },
    { "source": "/manifest.webmanifest", "destination": "/frontend/dist/manifest.webmanifest" },
    { "source": "/registerSW.js", "destination": "/frontend/dist/registerSW.js" },
    { "source": "/(.*)", "destination": "/frontend/dist/index.html" }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
    }
  ]
}
